# Copy this file to .env.local and add your real Anthropic key.
# Do not commit .env.local.

ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
NEXT_PUBLIC_LAB_TITLE=Procurement Exception Triage Agent
AGENT_MAX_ITERATIONS=8
AGENT_APPROVAL_THRESHOLD=25000

# Public-deployment guardrails (all optional; defaults shown)
RATE_LIMIT_PER_MINUTE=6
MAX_MESSAGE_CHARS=1500
DAILY_BUDGET_USD=5

# Cost estimation (Claude Haiku 4.5 list pricing per million tokens)
ANTHROPIC_INPUT_COST_PER_MTOK=1
ANTHROPIC_OUTPUT_COST_PER_MTOK=5
